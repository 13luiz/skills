{
  "skill_name": "harness-engineering-guide",
  "eval_strategy": "real-repo",
  "description": "Evaluation benchmarks using real open-source repositories. Each eval clones a specific release tag, runs the full audit flow, and compares against expected findings.",
  "execution": {
    "clone": "git clone --depth 1 --branch <tag> <repo> /tmp/harness-eval/<repo-name>",
    "audit": "bash scripts/harness-audit.sh /tmp/harness-eval/<repo-name> --profile <profile> --stage <stage> --blueprint",
    "report_output": "reports/<YYYY-MM-DD>_<repo-name>_eval.md",
    "validation": {
      "score_tolerance": 5,
      "key_findings_match_rate": 0.8
    },
    "report_path_note": "report_path values are OUTPUT destinations, not pre-existing files. Reports are generated when evals are run. Paths under examples/ serve as golden references once generated."
  },
  "evals": [
    {
      "id": "1a",
      "type": "real-repo",
      "name": "OpenClaw (Dec 2025 baseline)",
      "repo": "https://github.com/openclaw/openclaw",
      "tag": "v2.0.0-beta5",
      "profile": "monorepo",
      "stage": "mature",
      "language": "en",
      "purpose": "Historical baseline — harness state before date-based versioning",
      "expectations": {
        "score_range": [65, 78],
        "grade": "B-/C+",
        "key_findings": [
          "AGENTS.md quality — check line count and progressive disclosure",
          "CI pipeline exists and blocks on failure",
          "TypeScript strict mode configured",
          "Monorepo tooling (workspace configuration)",
          "Entropy management gaps likely present"
        ],
        "must_identify_anti_patterns": []
      },
      "report_path": "examples/2025-12_openclaw_v2.0.0-beta5_audit.md"
    },
    {
      "id": "1b",
